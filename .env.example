# Application Settings
DEBUG=True

# Security - Generate a secret key using: openssl rand -hex 32
SECRET_KEY=your-secret-key-here-change-in-production

# JWT Configuration (in minutes)
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=1440

# MongoDB Configuration
# IMPORTANT: The password in the URI must be URL-encoded!
# Use Python to encode: from urllib.parse import quote_plus; print(quote_plus("your-password"))
# Example: if password is "25%jA+x*fJes6Zu", encoded is "25%25jA%2Bx%2AfJes6Zu"
MONGODB_URI=mongodb+srv://username:ENCODED_PASSWORD_HERE@cluster0.bnltfut.mongodb.net/
MONGODB_NAME=aircraft_tickets

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000