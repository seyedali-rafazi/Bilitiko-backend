    {
      "name": "Flights",
      "item": [
        {
          "name": "Search Flights",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const list = pm.response.json();",
                  "    if (list.length > 0) {",
                  "        pm.collectionVariables.set('flight_id', list[0].id);",
                  "    }",
                  "    pm.test('Flights returned', () => pm.response.to.have.status(200));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/flights/search?origin=THR&destination=MHD&departure_date=2025-07-25&flight_class=economy&limit=20",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "flights", "search"],
              "query": [
                {"key": "origin", "value": "THR"},
                {"key": "destination", "value": "MHD"},
                {"key": "departure_date", "value": "2025-07-25"},
                {"key": "flight_class", "value": "economy"},
