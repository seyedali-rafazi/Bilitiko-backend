    {
      "name": "Admin — Data Seeding",
      "description": "Protected by X-Admin-Key header. Set {{admin_key}} to your SECRET_KEY from .env",
      "item": [
        {
          "name": "Seed Data (next 7 days)",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "X-Admin-Key", "value": "{{admin_key}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"days\": 7,\n  \"trips_per_pair\": 3,\n  \"clean\": false\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/admin/seed",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "seed"]
            },
            "description": "Generate flights, buses and trains for all city pairs for the next 7 days.\n\n- `days` — 1–30 (default 7)\n- `trips_per_pair` — trips per city-pair per day (default 3)\n- `clean` — set true to wipe existing future data first"
          }
        },
        {
          "name": "Seed Data (clean + regenerate)",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "X-Admin-Key", "value": "{{admin_key}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"days\": 7,\n  \"trips_per_pair\": 3,\n  \"clean\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/admin/seed",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "seed"]
            },
            "description": "Wipe all future data first, then regenerate fresh records."
          }
        },
        {
          "name": "Delete Future Data",
          "request": {
            "method": "DELETE",
            "header": [{"key": "X-Admin-Key", "value": "{{admin_key}}"}],
            "url": {
              "raw": "{{base_url}}/api/v1/admin/seed/future?days=7",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admin", "seed", "future"],
              "query": [{"key": "days", "value": "7"}]
            },
            "description": "Delete all flights and transport trips for the next N days without regenerating."
          }
        },
        {
          "name": "Seed Status",
          "request": {
            "method": "GET",
